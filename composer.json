{
  "name": "godie/overphp",
  "description": "Minimal PHP API framework with static client serving and CLI support",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "La Politzia",
      "email": "security@overphp.com"
    }
  ],
  "require": {
    "php": "^8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "bin": [
    "bin/overphp"
  ],
  "autoload": {
    "psr-4": {
      "OverPHP\\": "src/"
    },
    "files": [
      "src/Helpers/cors.php",
      "src/Helpers/database.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "OverPHP\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml"
  }
}
